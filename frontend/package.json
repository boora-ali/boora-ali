{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode development --host localhost --port 5173",
    "dev:preprod": "vite --mode preprod --host 0.0.0.0 --port 5173",
    "icons": "node scripts/generate-icons.mjs",
    "prebuild": "node scripts/generate-og-image.mjs",
    "build": "tsc -b && vite build",
    "build:preprod": "tsc -b && vite build --mode preprod",
    "build:prod": "tsc -b && vite build --mode production",
    "lint": "eslint .",
    "preview": "vite preview",
    "perf:preview": "vite preview --host 127.0.0.1 --port 4173",
    "perf:lighthouse:mobile": "lighthouse http://127.0.0.1:4173/login --output html --output-path ./lighthouse-report-mobile.html --chrome-flags='--headless=new --no-sandbox'",
    "perf:lighthouse:desktop": "lighthouse http://127.0.0.1:4173/login --preset=desktop --output html --output-path ./lighthouse-report-desktop.html --chrome-flags='--headless=new --no-sandbox'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "i18n:sync": "node ../scripts/po-to-i18n.cjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@lottiefiles/dotlottie-react": "^0.19.2",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.0.5",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^5.24.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "aeo.js": "^0.0.14",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "lighthouse": "^13.3.0",
    "postcss": "^8.5.12",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.10",
    "vitest": "^4.1.6"
  }
}
